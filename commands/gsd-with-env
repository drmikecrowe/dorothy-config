#!/usr/bin/env bash
# gsd-with-env: run gsd with environment injected from 1Password or varlock
set -euo pipefail

TOOL="gsd"

command -v op >/dev/null || { echo "ERROR: op (1Password CLI) required" >&2; exit 1; }
command -v varlock >/dev/null || { echo "ERROR: varlock not found on PATH" >&2; exit 1; }
command -v $TOOL >/dev/null || { echo "ERROR: $TOOL not found on PATH" >&2; exit 1; }

# Check if .env.schema exists in the current directory
if [ -f ".env.schema" ]; then
    # Run with varlock if schema is present
    exec varlock run --no-redact-stdout -- $TOOL "$@"
else
    # Inject 1Password secrets into the environment first
    eval "$(op-inject-env)"

    # Fallback to standard execution
    exec $TOOL "$@"
fi

