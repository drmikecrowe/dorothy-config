#!/usr/bin/env bash
# Rebuild config.local/1password.env from 1Password API Credential items with uppercase titles

set -euo pipefail

DOROTHY_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
OUT="$DOROTHY_DIR/config.local/1password.env"

op item list --categories "API Credential" --format json |
	jq -r '.[] | select(.title | test("^[A-Z0-9_-]+$")) | "\(.title)|\(.vault.name)"' |
	sort |
	while IFS='|' read -r title vault; do
		key="${title//-/_}"
		if [[ "$key" == "1TouchPoint" ]]; then continue; fi
		echo "export ${key}=op://${vault}/${title}/credential"
	done >"$OUT"

echo "Written to $OUT"
