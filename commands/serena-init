#!/usr/bin/env bash
# serena-init — initialize Serena project + .mcp.json for current git repo or worktree
# Sets up: .serena/project.yml, serena MCP, gsd-workflow MCP, codebase-memory-mcp
# Idempotent — safe to rerun. Merges into existing .mcp.json, never removes entries.
set -euo pipefail

SERENA_BIN="${SERENA_BIN:-$(which serena 2>/dev/null || echo "$HOME/.local/share/mise/shims/serena")}"

# Verify we're in a git repo
git_root=$(git rev-parse --show-toplevel 2>/dev/null) || {
    echo "Error: not in a git repository" >&2
    exit 1
}

# Detect worktree: git-dir differs from git-common-dir in linked worktrees and bare+worktree setups
git_dir=$(git rev-parse --git-dir 2>/dev/null)
git_common_dir=$(git rev-parse --git-common-dir 2>/dev/null)
git_dir_abs=$(realpath "$git_dir" 2>/dev/null || readlink -f "$git_dir" 2>/dev/null || echo "$git_dir")
git_common_dir_abs=$(realpath "$git_common_dir" 2>/dev/null || readlink -f "$git_common_dir" 2>/dev/null || echo "$git_common_dir")

is_worktree=false
[[ "$git_dir_abs" != "$git_common_dir_abs" ]] && is_worktree=true

# Get repo name: prefer remote URL, fall back to parent-of-.bare (bare repos), then dir name
repo_name=$(git remote get-url origin 2>/dev/null | sed 's|.*/||; s|\.git$||' | tr -d '\r') || true

if [[ -z "$repo_name" ]]; then
    bare_parent=$(dirname "$git_common_dir_abs" 2>/dev/null)
    candidate=$(basename "$bare_parent" 2>/dev/null)
    if [[ -n "$candidate" && "$candidate" != "." && "$candidate" != "/" ]]; then
        repo_name="$candidate"
    else
        repo_name=$(basename "$git_root")
    fi
fi

repo_name=$(echo "$repo_name" | tr '/ ' '--' | tr -s '-')
branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null | tr '/ ' '--' | tr -s '-') || branch="unknown"

main_branches=("main" "master" "develop" "dev")
is_main_branch=false
for mb in "${main_branches[@]}"; do
    [[ "$branch" == "$mb" ]] && is_main_branch=true && break
done

if [[ "$is_main_branch" == "true" ]]; then
    project_name="$repo_name"
else
    project_name="${repo_name}-${branch}"
fi

echo "Git root:    $git_root"
echo "Is worktree: $is_worktree"
echo "Branch:      $branch"
echo "Project:     $project_name"

# ── Step 1: .serena/project.yml ───────────────────────────────────────────────

serena_dir="$git_root/.serena"
project_yml="$serena_dir/project.yml"

if [[ -f "$project_yml" ]]; then
    if command -v sd &>/dev/null; then
        sd 'project_name:.*' "project_name: $project_name" "$project_yml"
    else
        sed -i "s/^project_name:.*/project_name: $project_name/" "$project_yml"
    fi
    echo "Updated:  $project_yml"
    "$SERENA_BIN" project create "$git_root" --name "$project_name" 2>/dev/null || true
else
    "$SERENA_BIN" project create "$git_root" --name "$project_name"
    echo "Created:  $project_yml"
fi

# ── Step 2: .mcp.json ─────────────────────────────────────────────────────────

echo ""
echo "Setting up .mcp.json..."

mcp_file="$git_root/.mcp.json"
existing="{}"
[[ -f "$mcp_file" ]] && existing=$(cat "$mcp_file")

# Ensure mcpServers key exists
merged=$(echo "$existing" | jq 'if .mcpServers then . else .mcpServers = {} end')

# ── serena ────────────────────────────────────────────────────────────────────
serena_abs=$(realpath "$SERENA_BIN" 2>/dev/null || echo "$SERENA_BIN")
if echo "$merged" | jq -e '.mcpServers.serena' > /dev/null 2>&1; then
    echo "Exists:   serena (skipped)"
else
    merged=$(echo "$merged" | jq \
        --arg cmd "$serena_abs" \
        --arg project "$git_root" \
        '.mcpServers.serena = {
            "type": "stdio",
            "command": $cmd,
            "args": ["start-mcp-server", "--context", "claude-code", "--project", $project],
            "env": {}
        }')
    echo "Added:    serena"
fi

# ── gsd-workflow ──────────────────────────────────────────────────────────────
gsd_cli=$(which gsd 2>/dev/null || echo "$HOME/.local/share/mise/shims/gsd")
node_bin=$(which node 2>/dev/null || echo "/usr/bin/node")
gsd_executors="$HOME/.gsd/agent/extensions/gsd/tools/workflow-tool-executors.js"
gsd_write_gate="$HOME/.gsd/agent/extensions/gsd/bootstrap/write-gate.js"

# Find gsd-pi mcp-server: resolve gsd symlink → gsd-pi dir → packages/mcp-server/dist/cli.js
gsd_mcp_server=""
if [[ -x "$gsd_cli" ]]; then
    gsd_real=$(realpath "$gsd_cli" 2>/dev/null || readlink -f "$gsd_cli" 2>/dev/null || "")
    if [[ -n "$gsd_real" ]]; then
        # gsd_real = .../node_modules/gsd-pi/dist/loader.js → go up 2 dirs to get gsd-pi root
        gsd_pi_dir=$(dirname "$(dirname "$gsd_real")")
        candidate="$gsd_pi_dir/packages/mcp-server/dist/cli.js"
        [[ -f "$candidate" ]] && gsd_mcp_server="$candidate"
    fi
fi

if [[ -n "$gsd_mcp_server" && -f "$gsd_executors" && -f "$gsd_write_gate" ]]; then
    if echo "$merged" | jq -e '.mcpServers["gsd-workflow"]' > /dev/null 2>&1; then
        echo "Exists:   gsd-workflow (skipped)"
    else
        merged=$(echo "$merged" | jq \
            --arg node "$node_bin" \
            --arg mcp_cli "$gsd_mcp_server" \
            --arg gsd_cli_path "$gsd_cli" \
            --arg executors "$gsd_executors" \
            --arg write_gate "$gsd_write_gate" \
            --arg project "$git_root" \
            '.mcpServers["gsd-workflow"] = {
                "command": $node,
                "args": [$mcp_cli],
                "cwd": $project,
                "env": {
                    "GSD_CLI_PATH": $gsd_cli_path,
                    "GSD_WORKFLOW_EXECUTORS_MODULE": $executors,
                    "GSD_WORKFLOW_WRITE_GATE_MODULE": $write_gate,
                    "GSD_PERSIST_WRITE_GATE_STATE": "1",
                    "GSD_WORKFLOW_PROJECT_ROOT": $project
                }
            }')
        echo "Added:    gsd-workflow"
    fi
else
    [[ -z "$gsd_mcp_server" ]] && echo "Skipped:  gsd-workflow (gsd-pi mcp-server not found)"
    [[ ! -f "$gsd_executors" ]] && echo "Skipped:  gsd-workflow (missing $gsd_executors)"
fi

# ── codebase-memory-mcp ───────────────────────────────────────────────────────
cbm_bin=$(which codebase-memory-mcp 2>/dev/null || echo "")
if [[ -n "$cbm_bin" ]]; then
    cbm_abs=$(realpath "$cbm_bin" 2>/dev/null || echo "$cbm_bin")
    if echo "$merged" | jq -e '.mcpServers["codebase-memory-mcp"]' > /dev/null 2>&1; then
        echo "Exists:   codebase-memory-mcp (skipped)"
    else
        merged=$(echo "$merged" | jq \
            --arg cmd "$cbm_abs" \
            --arg project "$git_root" \
            '.mcpServers["codebase-memory-mcp"] = {
                "type": "stdio",
                "command": $cmd,
                "args": ["--project-root", $project]
            }')
        echo "Added:    codebase-memory-mcp"
        echo "Note:     Run index_repository once to build the code graph"
    fi
else
    echo "Skipped:  codebase-memory-mcp (not installed — npm install -g codebase-memory-mcp)"
fi

# ── headroom ─────────────────────────────────────────────────────────────────
headroom_bin=$(which headroom 2>/dev/null || echo "")
if [[ -n "$headroom_bin" ]]; then
    headroom_abs=$(realpath "$headroom_bin" 2>/dev/null || echo "$headroom_bin")
    if echo "$merged" | jq -e '.mcpServers.headroom' > /dev/null 2>&1; then
        echo "Exists:   headroom (skipped)"
    else
        merged=$(echo "$merged" | jq \
            --arg cmd "$headroom_abs" \
            '.mcpServers.headroom = {
                "type": "stdio",
                "command": $cmd,
                "args": ["mcp", "serve"]
            }')
        echo "Added:    headroom (compress/retrieve/stats tools)"
        echo "Note:     For full proxy compression: headroom proxy + ANTHROPIC_BASE_URL=http://127.0.0.1:8787"
    fi
else
    echo "Skipped:  headroom (not installed — pip install 'headroom-ai[mcp]')"
fi

# ── context-mode ─────────────────────────────────────────────────────────────
ctxmode_bin=$(which context-mode 2>/dev/null || echo "")
if [[ -n "$ctxmode_bin" ]]; then
    if echo "$merged" | jq -e '.mcpServers["context-mode"]' > /dev/null 2>&1; then
        echo "Exists:   context-mode (skipped)"
    else
        merged=$(echo "$merged" | jq \
            --arg cmd "$ctxmode_bin" \
            '.mcpServers["context-mode"] = {
                "command": $cmd
            }')
        echo "Added:    context-mode"
    fi
else
    echo "Skipped:  context-mode (not installed)"
fi

echo "$merged" | jq '.' > "$mcp_file"
echo "Written:  $mcp_file"

# ── Done ──────────────────────────────────────────────────────────────────────

echo ""
echo "Done. Serena project '$project_name' ready at $git_root"
echo "Clients using --project-from-cwd will auto-detect this project."
