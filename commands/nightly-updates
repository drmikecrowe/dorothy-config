#!/usr/bin/env bash
# Nightly update job: yay -Syu + mise self-update + mise upgrade.
# Invoked by ~/.config/systemd/user/nightly-updates.timer.
# Safe to run manually: `nightly-updates`

set -uo pipefail

# shellcheck source=/dev/null
source "$(command -v obsidian-log)"
obs_init "Nightly Updates"

log() { printf '[%s] %s\n' "$(date -Iseconds)" "$*"; }

# ── SBOM / security secrets ───────────────────────────────────────────────────
# Encrypted at rest via strongbox; decrypted locally. Provides SOCKET_SECURITY_API_KEY, SNYK_TOKEN, etc.
_sbom_secrets="$(dirname "${BASH_SOURCE[0]}")/../config.local/sbom-security.sh"
if [[ -f "$_sbom_secrets" ]]; then
	# shellcheck source=/dev/null
	source "$_sbom_secrets"
else
	log "WARN: config.local/sbom-security.sh not found — security scanners may not authenticate"
fi
unset _sbom_secrets

# ── yay (Arch + AUR) ──────────────────────────────────────────────────────────
log "==> yay -Syu --noconfirm"
if command -v yay >/dev/null; then
	obs_run_warn "yay -Syu" yay -Syu --noconfirm --answerdiff=None --answerclean=None
else
	log "WARN: yay not installed, skipping"
	obs_note "yay" "Not installed, skipped."
fi

# ── mise (self + tools) ───────────────────────────────────────────────────────
if command -v mise >/dev/null; then
	log "==> mise self-update"
	obs_run_warn "mise self-update" mise self-update -y

	log "==> mise upgrade (global tools)"
	obs_run_warn "mise upgrade" mise upgrade -y
else
	log "WARN: mise not installed, skipping"
	obs_note "mise" "Not installed, skipped."
fi

# ── beads ─────────────────────────────────────────────────────────────────────
# managed by mise (aqua:gastownhall/beads); setup-util-beads installed a second
# copy to ~/.local/bin/bd that the mise install always shadowed on PATH

# ── CLI tools (extras not in SETUP_UTILS) ────────────────────────────────────
log "==> setup-cli-tools update"
if command -v setup-cli-tools >/dev/null; then
	obs_run_warn "setup-cli-tools" setup-cli-tools update
else
	log "WARN: setup-cli-tools not found, skipping"
	obs_note "setup-cli-tools" "Not found, skipped."
fi

# ── node global packages ──────────────────────────────────────────────────────
log "==> setup-node-global-utilities update"
if command -v setup-node-global-utilities >/dev/null; then
	obs_run_warn "setup-node-global-utilities" setup-node-global-utilities update
else
	log "WARN: setup-node-global-utilities not found, skipping"
	obs_note "setup-node-global-utilities" "Not found, skipped."
fi

# ── uv global tools ───────────────────────────────────────────────────────────
log "==> setup-uv-global-utilities update"
if command -v setup-uv-global-utilities >/dev/null; then
	obs_run_warn "setup-uv-global-utilities" setup-uv-global-utilities update
else
	log "WARN: setup-uv-global-utilities not found, skipping"
	obs_note "setup-uv-global-utilities" "Not found, skipped."
fi

# ── python global packages ────────────────────────────────────────────────────
log "==> python-global-packages"
if command -v python-global-packages >/dev/null; then
	obs_run_warn "python-global-packages" python-global-packages
else
	log "WARN: python-global-packages not found, skipping"
	obs_note "python-global-packages" "Not found, skipped."
fi

# ── supply chain audit ───────────────────────────────────────────────────────
log "==> supply chain audit"

# Run a security scanner: log its output to Obsidian (like obs_run_warn) but
# ALSO raise a real alert and record the finding when it exits non-zero, so the
# end-of-run Pushover summary fires. (obs_run_warn alone only logs a WARN.)
_sec_findings=()
audit_run() {
	local label="$1"; shift
	local out rc=0 icon="✅"
	out="$("$@" 2>&1)" || rc=$?
	printf '%s\n' "$out"
	[[ $rc -ne 0 ]] && icon="⚠️"
	printf '### %s %s\n```\n%s\n```\n\n' "$icon" "$label" \
		"$(printf '%s' "$out" | tail -30)" >>"$_OBS_LOG_FILE"
	if [[ $rc -ne 0 ]]; then
		obs_alert "$label reported issues (exit $rc)"
		_sec_findings+=("$label")
	fi
}

# --- snyk (npm globals — every mise-installed node version) ---
# Globals installed by mise have no top-level package.json/lockfile, and
# `npm root -g` only sees the active version. For each installed version,
# synthesize a manifest from the on-disk packages and symlink the real
# node_modules so snyk has dependencies to resolve.
_audit_node_globals() {
	local nm="$1" tmp
	tmp="$(mktemp -d)" || return 1
	# shellcheck disable=SC2064
	trap "rm -rf '$tmp'" RETURN
	ln -s "$nm" "$tmp/node_modules"
	python3 - "$nm" >"$tmp/package.json" <<'PY'
import sys, os, json
nm = sys.argv[1]
deps = {}
def add(d):
    try:
        with open(os.path.join(d, "package.json")) as f:
            p = json.load(f)
        deps[p["name"]] = p.get("version", "*")
    except Exception:
        pass
for entry in sorted(os.listdir(nm)):
    path = os.path.join(nm, entry)
    if not os.path.isdir(path):
        continue
    if entry.startswith("@"):            # scoped packages live one level down
        for sub in sorted(os.listdir(path)):
            add(os.path.join(path, sub))
    else:
        add(path)
json.dump({"name": "npm-globals-audit", "version": "0.0.0", "dependencies": deps},
          sys.stdout, indent=2)
PY
	( cd "$tmp" && snyk test --severity-threshold=high 2>&1 )
}

if command -v snyk >/dev/null; then
	declare -A _seen=()
	for _nm in "$HOME"/.local/share/mise/installs/node/*/lib/node_modules; do
		[[ -d "$_nm" ]] || continue
		# mise exposes version aliases (22, latest, lts-*) as symlinks; resolve
		# to the real install so each version is scanned exactly once.
		_real="$(realpath "$_nm")"
		[[ -n "${_seen[$_real]:-}" ]] && continue
		_seen[$_real]=1
		_ver="$(basename "$(dirname "$(dirname "$_real")")")"
		audit_run "snyk audit (node $_ver globals)" _audit_node_globals "$_real"
	done
	unset _nm _real _ver _seen
else
	obs_note "snyk" "Not installed — run setup-util-security-scanners."
fi

# --- pip-audit (Python) ---
# Prefer uv-installed binary (runs in its own venv); fall back to mise python module.
if command -v pip-audit >/dev/null; then
	audit_run "pip-audit (Python)" pip-audit --desc
else
	obs_note "pip-audit" "Not installed — run setup-util-security-scanners or uv tool install pip-audit."
fi

# --- osv-scanner ---
# Intentionally not run against npm globals: osv-scanner only understands
# lockfiles, and mise's global node_modules has none (it reports "No package
# sources found"). snyk above already covers the installed globals. Re-add an
# osv-scanner step here only for project trees that ship a real lockfile.

# ── notify ────────────────────────────────────────────────────────────────────
# commands.local is not on the systemd unit PATH, so call the sender by path.
if (( ${#_sec_findings[@]} > 0 )); then
	_pushover="$(dirname "${BASH_SOURCE[0]}")/../commands.local/send-pushover-notification"
	if [[ -x "$_pushover" ]]; then
		"$_pushover" \
			"Nightly audit flagged ${#_sec_findings[@]} scanner(s): ${_sec_findings[*]}. See Obsidian [[Alerts]]." \
			"⚠️ Security findings" 1 >/dev/null 2>&1 \
			|| log "WARN: pushover notification failed"
	else
		log "WARN: send-pushover-notification not found — ${#_sec_findings[@]} finding(s) not pushed"
	fi
	unset _pushover
fi

obs_finish
log "==> done"
