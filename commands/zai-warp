#!/bin/bash
# Z.AI wrapper for warp-terminal-oss Code
# Reads config from ~/.zai.json and launches warp-terminal-oss with the configured endpoint/models

set -euo pipefail

config="$HOME/.zai.json"

if ! command -v jq >/dev/null 2>&1; then
	echo "zc: jq is required (brew install jq | apt-get install jq)" >&2
	exit 1
fi

if [ ! -f "$config" ]; then
	echo "zc: missing $config" >&2
	exit 1
fi

if ! command -v warp-terminal-oss >/dev/null 2>&1; then
	echo "zc: warp-terminal-oss not found" >&2
	exit 1
fi

IFS=$'\t' read -r api_url api_key yolo haiku_model sonnet_model opus_model < <(
	jq -r '[.apiUrl // "", .apiKey // "", .yolo // false, .haikuModel // "", .sonnetModel // "", .opusModel // ""] | @tsv' "$config"
)

if [ -z "$api_url" ] || [ -z "$api_key" ]; then
	echo "zc: apiUrl/apiKey missing in $config" >&2
	exit 1
fi

[ -z "$haiku_model" ] && haiku_model="glm-4.5-air"
[ -z "$sonnet_model" ] && sonnet_model="glm-5.1"
[ -z "$opus_model" ] && opus_model="glm-5.1"

key_hint="${api_key:0:4}...${api_key: -4}"
echo "zai: endpoint=$api_url | haiku=$haiku_model | sonnet=$sonnet_model | opus=$opus_model | key=$key_hint"

export ANTHROPIC_BASE_URL="$api_url"
export ANTHROPIC_AUTH_TOKEN="$api_key"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$haiku_model"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$sonnet_model"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$opus_model"

exec warp-terminal-oss "$@"
